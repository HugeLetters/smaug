		"arkregex": "^0.0.5",
		"cheerio": "^1.2.0",
		"effect": "^4.0.0-beta.35",
		"googleapis": "^171.4.0",
		"html-to-text": "^9.0.5",
		"solid-js": "^1.9.11",
		"vinxi": "^0.5.11"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.14",
		"@effect/language-service": "^0.80.0",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/vite": "^4.1.18",
		"@types/bun": "^1.3.9",
